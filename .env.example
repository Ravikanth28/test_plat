# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database (MongoDB Atlas) ----
# Get this from https://cloud.mongodb.com  -> Connect -> Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/localmart?retryWrites=true&w=majority

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Razorpay (TEST mode keys from https://dashboard.razorpay.com) ----
# Leave blank to run online payments in DEMO/mock mode automatically.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Frontend (only needed for local dev) ----
# URL where the API is served. In production the same server serves the client.
CLIENT_URL=http://localhost:5173

# ---- Web Push (VAPID) ----
# Generate a pair with: npx web-push generate-vapid-keys
# Leave blank to disable background push (in-app notifications still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
